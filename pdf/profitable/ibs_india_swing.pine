//@version=6
// IBS Mean Reversion [India v2 — SWING]
// ─────────────────────────────────────────────────────────────────
// PURPOSE: Capture 1-3 day swing trades on Indian stocks that show
// active price movement. Buy oversold daily closes, sell on bounce.
//
// USE THIS ON: Daily timeframe (D)
// IDEAL UNIVERSE: NSE F&O stocks, large/mid-caps showing 2-4% daily ATR
// HOLDING PERIOD: 1-3 days (forced exit at 3 bars max)
// EXPECTED SETUPS: 2-5 trades per stock per month
//
// Improvements vs v1:
//   • Volatility filter — skips quiet stocks (need ATR ≥ 1.5%) and
//     hyper-volatile penny stocks (skip if ATR > 5%)
//   • Min price ₹100 — avoids penny stock false signals
//   • Liquidity ₹2 Cr — ensures fills on swing-sized positions
//   • Strict 3-bar time stop (was 5) — keeps capital cycling
//   • TP 2.5% / SL 1.5% (R:R = 1.67) — wider target for swing payoff
//   • 200-SMA trend filter — no falling knives
//   • IBS > 0.65 early-exit — book mean-reversion winners
//   • Gap-down filter — skip days that gap > 2% lower
//   • Optional Thursday filter — F&O weekly expiry pin

strategy("IBS Mean Reversion [India v2 — Swing]",
     overlay              = false,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 5,
     initial_capital      = 100000,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.05,
     slippage             = 2,
     calc_on_every_tick   = false,
     process_orders_on_close = false)

// ───────────────────────── Strategy Inputs ────────────────────────
ibs_entry = input.float(0.35, "IBS Entry Threshold",     step=0.05, minval=0.05, maxval=0.50, group="Entry",
     tooltip="Buy when previous bar's IBS < this value. 0.35 is sweet spot for Indian markets.")
ibs_exit  = input.float(0.65, "IBS Exit Threshold",      step=0.05, minval=0.50, maxval=0.95, group="Exit",
     tooltip="Exit when IBS > this — book the mean-reversion winner")
vol_mult  = input.float(1.0,  "Volume Multiplier (×SMA20)", step=0.1, minval=0, maxval=3, group="Entry",
     tooltip="Capitulation volume — 1.0× is balanced. Increase to 1.2-1.5× for stricter")
tp_pct    = input.float(2.5,  "Take Profit %",           step=0.1, minval=0.5, group="Risk")
sl_pct    = input.float(1.5,  "Stop Loss %",             step=0.1, minval=0.3, group="Risk")
max_bars  = input.int  (3,    "Max Bars in Trade",       minval=1, maxval=10,  group="Risk",
     tooltip="Force-exit after N days. 3 bars = strict 3-day swing limit")

// ───────────────────────── Filters ────────────────────────────────
use_trend     = input.bool (true, "Trend Filter (price > 200-SMA)",   group="Filters",
     tooltip="Only buy when above 200-day MA — avoids catching falling knives in downtrends")
trend_len     = input.int  (200,  "Trend SMA Length", minval=20, maxval=400, group="Filters")

use_volatility = input.bool (true, "Volatility Filter (movers only)",   group="Filters",
     tooltip="Stock must have meaningful daily range to be tradeable")
min_atr_pct   = input.float(1.5,  "Min ATR % (skip quiet)",  step=0.1, minval=0.5, group="Filters",
     tooltip="ATR(14) must be at least this % of price. Default 1.5% = active mover")
max_atr_pct   = input.float(5.0,  "Max ATR % (skip chaos)",  step=0.5, minval=2.0, group="Filters",
     tooltip="ATR(14) must be below this % of price. Default 5% blocks penny-stock chaos")

use_min_price = input.bool (true, "Min Price Filter",  group="Filters")
min_price     = input.float(100,  "Min Price (₹)", step=10, minval=1, group="Filters",
     tooltip="Avoid penny stocks where IBS gives false signals from thin trading")

use_gap       = input.bool (true, "Skip Gap-Down Days (>2%)", group="Filters")
gap_thresh    = input.float(2.0,  "Max Gap-Down %", step=0.1, minval=0.1, group="Filters")

use_liquidity = input.bool (true, "Liquidity Filter", group="Filters")
min_turnover  = input.float(2e7,  "Min Avg Daily Turnover (₹)", step=1e6, group="Filters",
     tooltip="Default ₹2 Cr. Swing positions are larger — need adequate liquidity")

skip_thursday = input.bool (false, "Skip Thursdays (F&O Weekly Expiry)", group="Filters",
     tooltip="Useful for index/F&O stocks where Thursday close is artificially pinned")

// ───────────────────────── Calculations ───────────────────────────
ibs        = (close - low) / (high - low)
vol_ma     = ta.sma(volume, 20)
trend_sma  = ta.sma(close, trend_len)
turnover   = ta.sma(volume * close, 20)
atr14      = ta.atr(14)
atr_pct    = atr14 / close * 100

// ──────────────────────── Filter Conditions ───────────────────────
trend_ok       = not use_trend      or close[1] > trend_sma[1]
volatility_ok  = not use_volatility or (atr_pct[1] >= min_atr_pct and atr_pct[1] <= max_atr_pct)
price_ok       = not use_min_price  or close[1] >= min_price
gap_ok         = not use_gap        or open >= close[1] * (1 - gap_thresh / 100)
liquidity_ok   = not use_liquidity  or turnover[1] >= min_turnover
not_thursday   = not skip_thursday  or dayofweek != dayofweek.thursday
volume_ok      = volume[1] > vol_ma[1] * vol_mult

// ─────────────────────────────── Entry ────────────────────────────
entry_signal = ibs[1] < ibs_entry
             and volume_ok
             and trend_ok
             and volatility_ok
             and price_ok
             and gap_ok
             and liquidity_ok
             and not_thursday

if entry_signal and strategy.position_size == 0
    strategy.entry("IBS_Long", strategy.long)

// ─────────────────────────── Exit Logic ───────────────────────────
if strategy.position_size > 0
    tp_level = strategy.position_avg_price * (1 + tp_pct / 100)
    sl_level = strategy.position_avg_price * (1 - sl_pct / 100)
    strategy.exit("Bracket", "IBS_Long", limit=tp_level, stop=sl_level)

    if ibs[1] > ibs_exit
        strategy.close("IBS_Long", comment="IBS>0.65")

    bars_in_trade = bar_index - strategy.opentrades.entry_bar_index(0)
    if bars_in_trade >= max_bars
        strategy.close("IBS_Long", comment="Time Stop")

// ───────────────────────── Visualization ──────────────────────────
plot(ibs, "IBS", color=color.new(color.blue, 0), linewidth=2)
hline(ibs_entry, "Entry Threshold", color=color.new(color.green, 30), linestyle=hline.style_dashed)
hline(ibs_exit,  "Exit Threshold",  color=color.new(color.red, 30),   linestyle=hline.style_dashed)
hline(0.5, "Mid", color=color.new(color.gray, 70), linestyle=hline.style_dotted)

would_have_entered = ibs[1] < ibs_entry and volume_ok
filter_blocked     = would_have_entered and not (trend_ok and volatility_ok and price_ok and gap_ok and liquidity_ok and not_thursday)
bgcolor(filter_blocked ? color.new(color.orange, 90) : na, title="Filter Blocked Entry")

// Status table (top-right corner)
var table info = table.new(position.top_right, 2, 8, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Filter",     text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(info, 1, 0, "Status",     text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(info, 0, 1, "Trend",      text_color=color.white)
    table.cell(info, 1, 1, trend_ok      ? "✓" : "✗", text_color=trend_ok      ? color.green : color.red)
    table.cell(info, 0, 2, "Volume",     text_color=color.white)
    table.cell(info, 1, 2, volume_ok     ? "✓" : "✗", text_color=volume_ok     ? color.green : color.red)
    table.cell(info, 0, 3, "ATR%",       text_color=color.white)
    table.cell(info, 1, 3, str.tostring(atr_pct, "#.##") + (volatility_ok ? " ✓" : " ✗"), text_color=volatility_ok ? color.green : color.red)
    table.cell(info, 0, 4, "Gap",        text_color=color.white)
    table.cell(info, 1, 4, gap_ok        ? "✓" : "✗", text_color=gap_ok        ? color.green : color.red)
    table.cell(info, 0, 5, "Liquidity",  text_color=color.white)
    table.cell(info, 1, 5, liquidity_ok  ? "✓" : "✗", text_color=liquidity_ok  ? color.green : color.red)
    table.cell(info, 0, 6, "IBS",        text_color=color.white)
    table.cell(info, 1, 6, str.tostring(ibs, "#.000"), text_color=color.white)
    table.cell(info, 0, 7, "Mode",       text_color=color.white)
    table.cell(info, 1, 7, "SWING",      text_color=color.aqua)
