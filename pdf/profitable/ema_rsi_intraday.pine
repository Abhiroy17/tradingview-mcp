//@author Alorse

//@version=6
strategy(title='Tendency EMA + RSI', shorttitle='EMA + RSI - Intraday', overlay=true, pyramiding=0, currency=currency.INR, default_qty_type=strategy.percent_of_equity, initial_capital=500000, default_qty_value=20, commission_type=strategy.commission.percent, commission_value=0.03, slippage=2)

// Session
i_marketSession = input.session('0915-1455', 'Market session', group='Session')

// Bollinger Bands
len = input.int(14, minval=1, title='Length', group='RSI')
src = input.source(close, 'Source', group='RSI')
rsi = ta.rsi(src, len)

// Moving Averages
len_a = input.int(10, minval=1, title='EMA A Length', group='Moving Averages')
out_a = ta.ema(close, len_a)
plot(out_a, title='EMA A', color=color.purple)

len_b = input.int(20, minval=1, title='EMA B Length', group='Moving Averages')
out_b = ta.ema(close, len_b)
plot(out_b, title='EMA B', color=color.orange)

len_c = input.int(100, minval=1, title='EMA C Length', group='Moving Averages')
out_c = ta.ema(close, len_c)
plot(out_c, title='EMA C', color=color.green)

// Risk management (percent of entry price)
i_tpPct = input.float(3.0, 'Take Profit %', minval=0.1, step=0.1, group='Risk')
i_slPct = input.float(1.5, 'Stop Loss %',   minval=0.1, step=0.1, group='Risk')

// Volume filter + session helper
i_volLen  = input.int(20,   'Volume MA Length',  minval=1,   group='Filters')
i_volMult = input.float(1.0, 'Volume Multiplier', minval=0.0, step=0.1, group='Filters')
barInSession(sess) => time(timeframe.period, sess) != 0
bool intradaySession = barInSession(i_marketSession)
volMA = ta.sma(volume, i_volLen)
volOK = volMA > 0 and volume > volMA * i_volMult

// Strategy Conditions
stratGroup = 'Strategy'
showLong = input.bool(true, title='Long entries', group=stratGroup)
showShort = input.bool(true, title='Short entries', group=stratGroup)
closeAfterXBars = input.bool(true, title='Time-stop (max bars held)', group=stratGroup)
xBars = input.int(24, title='# bars', group=stratGroup)
rsiExitLong  = input.int(70, 'RSI Exit Long',  group=stratGroup)
rsiExitShort = input.int(30, 'RSI Exit Short', group=stratGroup)

entryLong = ta.crossover(out_a, out_b) and out_a > out_c and close > open and volOK and intradaySession
exitLong = rsi > rsiExitLong

entryShort = ta.crossunder(out_a, out_b) and out_a < out_c and close < open and volOK and intradaySession
exitShort = rsi < rsiExitShort


var int nPastBars = 0
if strategy.position_size != 0
    nPastBars := nPastBars + 1
else
    nPastBars := 0
if closeAfterXBars and nPastBars >= xBars
    exitLong := true
    exitShort := true

// Long Entry
strategy.entry('Long', strategy.long, when=entryLong and showLong)
strategy.close('Long', when=exitLong)

// Short Entry
strategy.entry('Short', strategy.short, when=entryShort and showShort)
strategy.close('Short', when=exitShort)

// Hard percentage TP/SL (no-op while flat: avg price is na)
float longTP  = strategy.position_avg_price * (1 + i_tpPct / 100)
float longSL  = strategy.position_avg_price * (1 - i_slPct / 100)
float shortTP = strategy.position_avg_price * (1 - i_tpPct / 100)
float shortSL = strategy.position_avg_price * (1 + i_slPct / 100)
strategy.exit('L-Exit', from_entry='Long',  limit=longTP,  stop=longSL)
strategy.exit('S-Exit', from_entry='Short', limit=shortTP, stop=shortSL)

// Session square-off
if (not intradaySession) and (strategy.position_size != 0)
    strategy.close_all(comment='Square-off')

