//@version=6
// IBS Mean Reversion [India — INTRADAY]
// ─────────────────────────────────────────────────────────────────
// PURPOSE: Same-day intraday mean reversion. Catch oversold dips on
// liquid Indian stocks during the trading session, exit before close.
//
// USE THIS ON: 5m, 15m, 30m, or 1H timeframes
// IDEAL UNIVERSE: F&O top 50, NIFTY/BANKNIFTY, large-caps with high turnover
// HOLDING PERIOD: Minutes to hours — ALL positions force-closed at 3:15 PM IST
// EXPECTED SETUPS: 1-4 trades per stock per day (session-bound)
//
// Indian Intraday Specifics:
//   • Session: 09:15 – 15:30 IST
//   • Entry window: 09:30 – 14:30 (skip first 15 min volatility, last 60 min noise)
//   • Force exit: at 15:00 IST (15 min before close to avoid slippage)
//   • Skip Thursday afternoon — F&O weekly expiry pin distorts price
//   • VWAP filter (not 200-SMA) — VWAP is the intraday king in India
//   • Tighter R:R: TP 0.7% / SL 0.5%
//   • Stricter IBS: 0.25 entry / 0.75 exit (intraday noise needs deeper signal)
//   • Stricter volume: 1.5× SMA20 (intraday needs liquidity confirmation)

strategy("IBS Mean Reversion [India — Intraday]",
     overlay              = false,
     default_qty_type     = strategy.percent_of_equity,
     default_qty_value    = 5,
     initial_capital      = 100000,
     commission_type      = strategy.commission.percent,
     commission_value     = 0.05,
     slippage             = 3,
     calc_on_every_tick   = false,
     process_orders_on_close = true)

// Warn if not used on intraday TF
if barstate.islastconfirmedhistory and not timeframe.isintraday
    runtime.error("This is an INTRADAY strategy. Use on 5m / 15m / 30m / 1H timeframes. " +
                  "For daily swing trades, use 'IBS Mean Reversion [India v2 — Swing]'.")

// ───────────────────────── Strategy Inputs ────────────────────────
ibs_entry  = input.float(0.25, "IBS Entry Threshold",    step=0.05, minval=0.05, maxval=0.45, group="Entry",
     tooltip="Stricter than swing — intraday IBS noise requires deeper oversold")
ibs_exit   = input.float(0.75, "IBS Exit Threshold",     step=0.05, minval=0.55, maxval=0.95, group="Exit",
     tooltip="Let winners run a bit further intraday")
vol_mult   = input.float(1.5,  "Volume Multiplier (×SMA20)", step=0.1, minval=0, maxval=5, group="Entry",
     tooltip="Intraday needs strong volume confirmation. 1.5× catches real moves")
tp_pct     = input.float(0.7,  "Take Profit %",          step=0.1, minval=0.1, group="Risk")
sl_pct     = input.float(0.5,  "Stop Loss %",            step=0.1, minval=0.1, group="Risk")
max_minutes = input.int (60,   "Max Holding (minutes)",  minval=5, maxval=300, group="Risk",
     tooltip="Force-exit after N minutes. 60 min default = give move time but not all session")

// ───────────────────────── Filters ────────────────────────────────
use_vwap      = input.bool (true, "VWAP Trend Filter",  group="Filters",
     tooltip="Only buy when price > VWAP — intraday momentum confirmation")

use_volatility = input.bool (true, "Volatility Filter (movers only)",   group="Filters")
min_atr_pct   = input.float(0.15, "Min ATR % (skip quiet)", step=0.05, minval=0.05, group="Filters",
     tooltip="ATR(14) on intraday TF must be ≥ this % of price. Default 0.15% = active")

use_liquidity = input.bool (true, "Liquidity Filter", group="Filters")
min_turnover_lac  = input.float(50,  "Min Avg Turnover (₹ Lac/bar)", step=10, group="Filters",
     tooltip="Default ₹50 Lac per bar. Increase for top-50 F&O liquidity")

skip_thursday_pm = input.bool (true, "Skip Thursday 14:00+ (Expiry Pin)", group="Filters",
     tooltip="Avoid Thursday afternoon F&O expiry pin action")

// Momentum confirmation (Phase I: MACD locked on, RSI opt-in)
use_rsi       = input.bool (false, "RSI Oversold Confirm", group="Momentum",
     tooltip="Require current-bar RSI < threshold. NOTE: <30 is too strict for 15m and zeroes out entries; 40 is usable.")
rsi_len       = input.int  (14,    "RSI Length", minval=2, maxval=50, group="Momentum")
rsi_max       = input.float(40,    "RSI Max (oversold)", step=1, minval=10, maxval=50, group="Momentum")
use_macd      = input.bool (true,  "MACD Histogram Rising", group="Momentum",
     tooltip="Require MACD histogram turning up on current bar. Phase I: LOCKED ON — took large_cap 15m from -16.4% to -5.6%, halved overtrading, ~doubled win rate.")

// ───────────────────────── Session Inputs ─────────────────────────
entry_window_start = input.session("0930-1430", "Entry Window (IST)", group="Session",
     tooltip="Allowed entry times. Default skips first 15 min and last 60 min")
exit_session_start = input.session("1500-1530", "Force-Exit Window (IST)", group="Session",
     tooltip="All positions force-closed during this window")

// ───────────────────────── Calculations ───────────────────────────
ibs        = (close - low) / (high - low)
vol_ma     = ta.sma(volume, 20)
vwap_val   = ta.vwap(hlc3)
atr14      = ta.atr(14)
atr_pct    = atr14 / close * 100
turnover_bar = volume * close
turnover_sma = ta.sma(turnover_bar, 20)
rsi_val    = ta.rsi(close, rsi_len)
[macd_line, macd_signal, macd_hist] = ta.macd(close, 12, 26, 9)

// Session detection
ist_tz = "Asia/Kolkata"
in_entry_window = not na(time(timeframe.period, entry_window_start, ist_tz))
in_exit_window  = not na(time(timeframe.period, exit_session_start, ist_tz))
is_thursday_pm  = dayofweek == dayofweek.thursday and hour(time, ist_tz) >= 14

// ──────────────────────── Filter Conditions ───────────────────────
vwap_ok       = not use_vwap        or close > vwap_val
volatility_ok = not use_volatility  or atr_pct >= min_atr_pct
liquidity_ok  = not use_liquidity   or turnover_sma >= (min_turnover_lac * 100000)  // Lac → Rupees
thursday_ok   = not skip_thursday_pm or not is_thursday_pm
volume_ok     = volume[1] > vol_ma[1] * vol_mult
rsi_ok        = not use_rsi         or rsi_val < rsi_max
macd_ok       = not use_macd        or macd_hist > macd_hist[1]

// ─────────────────────────────── Entry ────────────────────────────
entry_signal = ibs[1] < ibs_entry
             and volume_ok
             and vwap_ok
             and volatility_ok
             and liquidity_ok
             and thursday_ok
             and rsi_ok
             and macd_ok
             and in_entry_window
             and not in_exit_window

if entry_signal and strategy.position_size == 0
    strategy.entry("IBS_Long", strategy.long)

// ─────────────────────────── Exit Logic ───────────────────────────
if strategy.position_size > 0
    tp_level = strategy.position_avg_price * (1 + tp_pct / 100)
    sl_level = strategy.position_avg_price * (1 - sl_pct / 100)
    strategy.exit("Bracket", "IBS_Long", limit=tp_level, stop=sl_level)

    // High-IBS exit (mean reversion completed)
    if ibs[1] > ibs_exit
        strategy.close("IBS_Long", comment="IBS>"+ str.tostring(ibs_exit, "#.##"))

    // Time-based exit (in minutes — works on any TF)
    trade_duration_min = (time - strategy.opentrades.entry_time(0)) / 60000
    if trade_duration_min >= max_minutes
        strategy.close("IBS_Long", comment="Time")

    // Force EOD exit
    if in_exit_window
        strategy.close("IBS_Long", comment="EOD")

// ───────────────────────── Visualization ──────────────────────────
plot(ibs, "IBS", color=color.new(color.blue, 0), linewidth=2)
hline(ibs_entry, "Entry Threshold", color=color.new(color.green, 30), linestyle=hline.style_dashed)
hline(ibs_exit,  "Exit Threshold",  color=color.new(color.red, 30),   linestyle=hline.style_dashed)
hline(0.5, "Mid", color=color.new(color.gray, 70), linestyle=hline.style_dotted)

// Background: green during entry window, red during exit window
bgcolor(in_entry_window  ? color.new(color.green, 95) : na, title="Entry Window")
bgcolor(in_exit_window   ? color.new(color.red, 90)   : na, title="Exit Window")

// Filter-blocked highlight
would_have_entered = ibs[1] < ibs_entry and volume_ok and in_entry_window
filter_blocked = would_have_entered and not (vwap_ok and volatility_ok and liquidity_ok and thursday_ok)
bgcolor(filter_blocked ? color.new(color.orange, 80) : na, title="Filter Blocked")

// Status table (top-right corner)
var table info = table.new(position.top_right, 2, 9, bgcolor=color.new(color.black, 80), border_width=1)
if barstate.islast
    table.cell(info, 0, 0, "Filter",     text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(info, 1, 0, "Status",     text_color=color.white, bgcolor=color.new(color.gray, 50))
    table.cell(info, 0, 1, "Window",     text_color=color.white)
    table.cell(info, 1, 1, in_exit_window ? "EXIT" : in_entry_window ? "ENTRY" : "WAIT",
                                      text_color=in_exit_window ? color.red : in_entry_window ? color.green : color.yellow)
    table.cell(info, 0, 2, "VWAP",       text_color=color.white)
    table.cell(info, 1, 2, vwap_ok       ? "✓" : "✗", text_color=vwap_ok       ? color.green : color.red)
    table.cell(info, 0, 3, "Volume",     text_color=color.white)
    table.cell(info, 1, 3, volume_ok     ? "✓" : "✗", text_color=volume_ok     ? color.green : color.red)
    table.cell(info, 0, 4, "ATR%",       text_color=color.white)
    table.cell(info, 1, 4, str.tostring(atr_pct, "#.##") + (volatility_ok ? " ✓" : " ✗"), text_color=volatility_ok ? color.green : color.red)
    table.cell(info, 0, 5, "Liquidity",  text_color=color.white)
    table.cell(info, 1, 5, liquidity_ok  ? "✓" : "✗", text_color=liquidity_ok  ? color.green : color.red)
    table.cell(info, 0, 6, "Thursday",   text_color=color.white)
    table.cell(info, 1, 6, thursday_ok   ? "✓" : "✗", text_color=thursday_ok   ? color.green : color.red)
    table.cell(info, 0, 7, "IBS",        text_color=color.white)
    table.cell(info, 1, 7, str.tostring(ibs, "#.000"), text_color=color.white)
    table.cell(info, 0, 8, "Mode",       text_color=color.white)
    table.cell(info, 1, 8, "INTRADAY",   text_color=color.aqua)
