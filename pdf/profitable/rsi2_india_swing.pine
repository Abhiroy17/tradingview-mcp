//@version=6
strategy("RSI(2) India Swing", overlay=false, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.03)

// Larry Connors RSI(2) mean-reversion, tuned for Indian equities (NSE/BSE).
// Entry: RSI(2) crosses BELOW 30 with above-average volume.
// Exit: TP 1.5%, SL 1.0%, time-stop after 5 bars, or RSI(2) > 50.

rsi_length    = input.int(2,    "RSI Length",          minval=1)
rsi_oversold  = input.int(10,   "RSI Oversold")
rsi_midline   = input.int(50,   "RSI Exit")
vol_len       = input.int(20,   "Volume SMA Length",   minval=1)
max_bars_held = input.int(5,    "Max Bars Held",       minval=1)
tp_percent    = input.float(1.0,"Take Profit %",       step=0.1)
sl_percent    = input.float(1.0,"Stop Loss %",         step=0.1)

rsi_value = ta.rsi(close, rsi_length)
volume_ma = ta.sma(volume, vol_len)

// Cross-down detection: RSI ENTERED oversold THIS bar (not "still in oversold")
entry_condition = rsi_value < rsi_oversold and rsi_value[1] >= rsi_oversold and volume > volume_ma

exit_rsi  = strategy.position_size > 0 and rsi_value > rsi_midline
exit_time = strategy.position_size > 0 and (bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)) >= max_bars_held

if entry_condition and strategy.position_size == 0
    strategy.entry("RSI2_Long", strategy.long)

// FIX: compute TP/SL AFTER fill, against actual position_avg_price (was 0 on entry bar before).
if strategy.position_size > 0
    avg_p    = strategy.position_avg_price
    tp_level = avg_p * (1 + tp_percent / 100)
    sl_level = avg_p * (1 - sl_percent / 100)
    strategy.exit("RSI2_Exit", "RSI2_Long", limit=tp_level, stop=sl_level)

if exit_rsi or exit_time
    strategy.close("RSI2_Long", comment=exit_rsi ? "RSI>50" : "MaxBars")

plot(rsi_value, "RSI(2)", color=color.blue, linewidth=2)
hline(rsi_oversold, "Oversold", color=color.new(color.green, 30))
hline(rsi_midline,  "Exit",     color=color.new(color.orange, 30))

alertcondition(entry_condition, title="RSI(2) Entry", message="RSI(2) cross below 30 with volume confirmation")
