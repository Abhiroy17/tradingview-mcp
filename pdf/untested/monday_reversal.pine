//@version=6
strategy("Monday Reversal", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.03)

// Buy Monday opens that gap down on oversold RSI + volume — capture the
// Sunday-news/weekend-noise reversion. Exit TP 1.5% / SL 0.8% / max 5 bars.

rsi_thresh    = input.int(40,   "RSI(5) Threshold",  minval=10, maxval=60)
vol_len       = input.int(20,   "Volume SMA Length")
tp_pct        = input.float(1.5,"Take Profit %", step=0.1)
sl_pct        = input.float(0.8,"Stop Loss %",   step=0.1)
max_bars_held = input.int(5,    "Max Bars Held", minval=1)

is_monday = dayofweek(time) == dayofweek.monday
rsi5      = ta.rsi(close, 5)
vol_ma    = ta.sma(volume, vol_len)

entry_condition = is_monday and open < close[1] and rsi5 < rsi_thresh and volume > vol_ma

if entry_condition and strategy.position_size == 0
    strategy.entry("Monday_Long", strategy.long)

// FIX: compute TP/SL AFTER fill against actual position_avg_price (was 0 at signal bar).
if strategy.position_size > 0
    avg_p    = strategy.position_avg_price
    tp_level = avg_p * (1 + tp_pct / 100)
    sl_level = avg_p * (1 - sl_pct / 100)
    strategy.exit("Monday_Exit", "Monday_Long", limit=tp_level, stop=sl_level)

// Time stop
if strategy.position_size > 0 and (bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)) >= max_bars_held
    strategy.close("Monday_Long", comment="MaxBars")
