//@version=6
strategy("Overnight Swing", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.03)

// Buy strong-close days (close in top 10% of bar range) above SMA50 with volume confirmation,
// hold 1-2 bars overnight. Asymmetric R:R 1.5% TP / 0.8% SL favours small frequent wins.

sma_len           = input.int(50,    "SMA Length")
vol_len           = input.int(20,    "Volume SMA Length")
vol_mult          = input.float(1.5, "Volume Multiplier", step=0.1)
close_pos_thresh  = input.float(0.9, "Close Position Threshold (top X% of range)", minval=0.5, maxval=1.0, step=0.05)
tp_pct            = input.float(1.5, "Take Profit %", step=0.1)
sl_pct            = input.float(0.8, "Stop Loss %",   step=0.1)
max_bars_held     = input.int(2,     "Max Bars Held", minval=1)

sma_val   = ta.sma(close, sma_len)
vol_ma    = ta.sma(volume, vol_len)
range_now = high - low
close_pos = range_now > 0 ? (close - low) / range_now : 0
close_top = close_pos >= close_pos_thresh

entry_condition = close_top and volume > vol_ma * vol_mult and close > sma_val

if entry_condition and strategy.position_size == 0
    strategy.entry("ON_Long", strategy.long)

if strategy.position_size > 0
    avg_p    = strategy.position_avg_price
    tp_level = avg_p * (1 + tp_pct / 100)
    sl_level = avg_p * (1 - sl_pct / 100)
    strategy.exit("ON_Exit", "ON_Long", limit=tp_level, stop=sl_level)

// Time stop: close after max_bars_held bars
if strategy.position_size > 0 and (bar_index - strategy.opentrades.entry_bar_index(strategy.opentrades - 1)) >= max_bars_held
    strategy.close("ON_Long", comment="MaxBars")

plot(sma_val, "SMA", color=color.orange)
