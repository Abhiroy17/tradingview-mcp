//@version=6
strategy("IBS Mean Reversion (Generic)", overlay=true, default_qty_type=strategy.percent_of_equity, default_qty_value=2, initial_capital=100000, commission_type=strategy.commission.percent, commission_value=0.03)

// Generic IBS mean-reversion (no India-specific tuning).
// Buy when prior bar's IBS < 0.20 (close near low) with volume confirmation.
// Exit TP 1.5% / SL 1.0% / signal exit when close > prev close.

ibs_thresh = input.float(0.20,"IBS Entry Threshold", step=0.05, minval=0.05, maxval=0.5)
vol_len    = input.int(20,    "Volume SMA Length")
tp_pct     = input.float(1.5, "Take Profit %", step=0.1)
sl_pct     = input.float(1.0, "Stop Loss %",   step=0.1)

ibs    = (close - low) / (high - low)
vol_ma = ta.sma(volume, vol_len)

entry_condition = ibs[1] < ibs_thresh and volume[1] > vol_ma[1]
exit_condition  = strategy.position_size > 0 and close > close[1]

if entry_condition and strategy.position_size == 0
    strategy.entry("IBS_Long", strategy.long)

// FIX: compute TP/SL AFTER fill against actual position_avg_price.
if strategy.position_size > 0
    avg_p    = strategy.position_avg_price
    tp_level = avg_p * (1 + tp_pct / 100)
    sl_level = avg_p * (1 - sl_pct / 100)
    strategy.exit("IBS_Exit", "IBS_Long", limit=tp_level, stop=sl_level)

if exit_condition
    strategy.close("IBS_Long", comment="BounceClose")

plot(ibs, "IBS", color=color.blue)
hline(0.20, "Oversold",   color=color.red)
hline(0.80, "Overbought", color=color.green)
