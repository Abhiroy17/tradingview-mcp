//@version=6
strategy("Universal Breakout [India Intraday]",
     overlay=true,
     default_qty_type=strategy.percent_of_equity,
     default_qty_value=20,
     calc_on_every_tick=false,
     process_orders_on_close=false,
     pyramiding=0,
     initial_capital=200000,
     currency=currency.INR,
     commission_type=strategy.commission.percent,
     commission_value=0.055,
     slippage=3)

// ╔══════════════════════════════════════════════════════════════╗
// ║  Universal Breakout Strategy — India Intraday Edition       ║
// ║  Tuned for NSE/BSE session, costs, and risk management     ║
// ║                                                             ║
// ║  Fixes vs original:                                         ║
// ║  • Force-exit before 15:15 IST (broker square-off at 15:25)║
// ║  • ATR-based SL/TP per trade (risk-reward enforced)        ║
// ║  • No repainting (calc_on_every_tick=false)                ║
// ║  • 20% equity sizing (not 100%)                            ║
// ║  • Commission 0.055% models India intraday round-trip      ║
// ║  • Slippage 3 ticks (conservative for Nifty/BankNifty)     ║
// ║  • Gap filter: skip first 15 min of session                ║
// ║  • Max 3 trades/day cap (anti-whipsaw)                     ║
// ╚══════════════════════════════════════════════════════════════╝

//@author: KedArc Quant (improved for India intraday by Copilot)

// ═══════════════════════ INPUTS ═══════════════════════════════

// ── Strategy Parameters ──
len       = input.int(20, "Lookback Period", minval=5, maxval=100)
bbMult    = input.float(2.0, "Bollinger Multiplier", minval=0.5, step=0.1)
mode      = input.string("Prev Day",
     title="Breakout Mode",
     options=["Prev Day", "Bollinger", "Volume", "ATR Stop", "EMA Trend", "RSI Confirm", "Candle Confirm"])

// ── Risk Management ──
slMult    = input.float(1.5, "Stop Loss (ATR multiplier)", minval=0.5, step=0.1, tooltip="SL = entry ± ATR × this value")
tpMult    = input.float(2.5, "Take Profit (ATR multiplier)", minval=1.0, step=0.1, tooltip="TP = entry ± ATR × this value. Should be > SL for positive expectancy")
maxTrades = input.int(3, "Max Trades Per Day", minval=1, maxval=10, tooltip="Anti-whipsaw: stop trading after N entries per session")
riskPct   = input.float(1.0, "Risk Per Trade (%)", minval=0.1, maxval=5.0, step=0.1, tooltip="Position size based on this % of equity risked per trade")

// ── Session (IST-aware, NSE) ──
entryStart = input.session("0930-1430", "Entry Window (IST)", tooltip="Skip opening 15 min (gap noise) + last hour (close noise)")
forceExit  = input.int(1515, "Force Exit Time (HHMM IST)", minval=1500, maxval=1525, tooltip="All positions closed before broker auto-square-off")

// ── Filters ──
gapFilterPct  = input.float(2.0, "Gap Filter (%)", minval=0.0, step=0.5, tooltip="Skip signals if open gaps > X% from prev close (gap-through risk)")
minVolMult    = input.float(1.2, "Min Volume (× SMA)", minval=0.5, step=0.1, tooltip="Global volume filter: all modes require volume above this threshold")

// ── Display ──
showTable   = input.bool(true, "Show Info Table")
showStats   = input.bool(true, "Show P&L Stats")
showLevels  = input.bool(true, "Show Breakout Levels")
tableCorner = input.string("Top Right", "Table Corner", options=["Top Right","Top Left","Bottom Right","Bottom Left"])

// ═══════════════════════ SESSION LOGIC ════════════════════════

// IST session detection (NSE continuous: 09:15 - 15:30)
inEntryWindow = not na(time(timeframe.period, entryStart))

// Force-exit time check (HHMM integer comparison in exchange timezone)
currentHHMM = hour * 100 + minute
isForceExitTime = currentHHMM >= forceExit

// New session detection (for trade counting)
isNewDay = ta.change(time("D")) != 0

// ═══════════════════════ CORE LEVELS ═════════════════════════

// Previous day high/low (no lookahead bias — using confirmed [1] bar)
prevHigh = request.security(syminfo.tickerid, "D", high[1], lookahead=barmerge.lookahead_on)
prevLow  = request.security(syminfo.tickerid, "D", low[1],  lookahead=barmerge.lookahead_on)
prevClose = request.security(syminfo.tickerid, "D", close[1], lookahead=barmerge.lookahead_on)

// N-bar high/low (from previous bars only — no current bar)
hhPrev = ta.highest(high[1], len)
llPrev = ta.lowest(low[1], len)

// Bollinger Bands
[basis, bbUpper, bbLower] = ta.bb(close, len, bbMult)

// ATR for stops (14-period is standard; use `len` for consistency with lookback)
atr14 = ta.atr(14)

// ═══════════════════════ FILTERS ═════════════════════════════

// Volume confirmation (global — all modes)
volSma     = ta.sma(volume, len)
volConfirm = volume > volSma * minVolMult

// Gap filter: reject signals on bars where open gapped excessively
gapPct     = prevClose > 0 ? math.abs(open - prevClose) / prevClose * 100 : 0
isGapDay   = gapPct > gapFilterPct and barstate.isconfirmed

// EMA trend (for EMA Trend mode)
emaFast = ta.ema(close, 9)
emaSlow = ta.ema(close, 21)
trendUp   = emaFast > emaSlow
trendDown = emaFast < emaSlow

// RSI
rsiVal = ta.rsi(close, 14)

// Candle type
bullishCndl = close > open and close > close[1]
bearishCndl = close < open and close < close[1]
candleType  = bullishCndl ? "Bullish" : bearishCndl ? "Bearish" : "Neutral"

// ═══════════════════════ TRADE COUNTING ══════════════════════

// Track trades per day to enforce maxTrades cap
var int tradesToday = 0
if isNewDay
    tradesToday := 0

canTrade = tradesToday < maxTrades

// ═══════════════════════ BREAKOUT SIGNALS ════════════════════

// Base breakout detection (bar-close confirmed, no repainting)
longBase  = ta.crossover(close, hhPrev)
shortBase = ta.crossunder(close, llPrev)

// Mode-specific conditions
longCond =
     mode == "Prev Day"       ? ta.crossover(close, prevHigh) :
     mode == "Bollinger"      ? ta.crossover(close, bbUpper)  :
     mode == "Volume"         ? longBase  and volConfirm :
     mode == "ATR Stop"       ? longBase  and (close - close[1] > atr14 * 0.5) :
     mode == "EMA Trend"      ? longBase  and trendUp :
     mode == "RSI Confirm"    ? longBase  and (rsiVal > 55 and rsiVal < 75) :
     mode == "Candle Confirm" ? longBase  and bullishCndl :
     false

shortCond =
     mode == "Prev Day"       ? ta.crossunder(close, prevLow) :
     mode == "Bollinger"      ? ta.crossunder(close, bbLower) :
     mode == "Volume"         ? shortBase and volConfirm :
     mode == "ATR Stop"       ? shortBase and (close[1] - close > atr14 * 0.5) :
     mode == "EMA Trend"      ? shortBase and trendDown :
     mode == "RSI Confirm"    ? shortBase and (rsiVal < 45 and rsiVal > 25) :
     mode == "Candle Confirm" ? shortBase and bearishCndl :
     false

// ═══════════════════════ COMPOSITE GATE ══════════════════════

// All conditions must pass for entry (session + volume + gap + trade cap)
longSignal  = longCond  and inEntryWindow and volConfirm and not isGapDay and canTrade and not isForceExitTime
shortSignal = shortCond and inEntryWindow and volConfirm and not isGapDay and canTrade and not isForceExitTime

// ═══════════════════════ ORDERS + RISK ═══════════════════════

// ATR-based stop-loss and take-profit (calculated at signal bar)
longSL  = close - atr14 * slMult
longTP  = close + atr14 * tpMult
shortSL = close + atr14 * slMult
shortTP = close - atr14 * tpMult

if longSignal and strategy.position_size == 0
    strategy.entry("Long", strategy.long)
    strategy.exit("Long Exit", "Long", stop=longSL, limit=longTP)
    tradesToday += 1

if shortSignal and strategy.position_size == 0
    strategy.entry("Short", strategy.short)
    strategy.exit("Short Exit", "Short", stop=shortSL, limit=shortTP)
    tradesToday += 1

// ═══════════════════════ FORCE EXIT (EOD) ════════════════════

// Close all positions before broker auto-square-off
// This runs EVERY bar after forceExit time — catches any remaining position
if isForceExitTime and strategy.position_size != 0
    strategy.close_all(comment="EOD Exit")

// ═══════════════════════ PLOTS ═══════════════════════════════

// Level plots (conditional on mode + toggle)
plot(showLevels and mode == "Prev Day" ? prevHigh : na, "Prev High", color=color.new(color.green, 20), linewidth=2)
plot(showLevels and mode == "Prev Day" ? prevLow  : na, "Prev Low",  color=color.new(color.red, 20),   linewidth=2)

plot(showLevels and mode != "Bollinger" and mode != "Prev Day" ? hhPrev : na, "HH (len)", color=color.new(color.teal, 30))
plot(showLevels and mode != "Bollinger" and mode != "Prev Day" ? llPrev : na, "LL (len)", color=color.new(color.orange, 30))

plot(showLevels and mode == "Bollinger" ? bbUpper : na, "BB Upper", color=color.new(color.fuchsia, 20))
plot(showLevels and mode == "Bollinger" ? basis   : na, "BB Basis", color=color.new(color.gray, 60))
plot(showLevels and mode == "Bollinger" ? bbLower : na, "BB Lower", color=color.new(color.aqua, 20))

// Signal markers (only on confirmed entries)
plotshape(longSignal  and strategy.position_size[1] == 0, title="Long",  location=location.belowbar, color=color.green, style=shape.triangleup,   size=size.small, text="BUY")
plotshape(shortSignal and strategy.position_size[1] == 0, title="Short", location=location.abovebar, color=color.red,   style=shape.triangledown, size=size.small, text="SELL")

// ═══════════════════════ INFO TABLE ══════════════════════════

var table infoTbl = na
if barstate.isfirst
    pos = tableCorner == "Top Right" ? position.top_right :
          tableCorner == "Top Left"  ? position.top_left :
          tableCorner == "Bottom Right" ? position.bottom_right :
          position.bottom_left
    infoTbl := table.new(pos, columns=2, rows=11, border_width=1)

f_set(row, label, value, txtColor=color.white) =>
    table.cell(infoTbl, 0, row, label, text_color=color.gray,  text_halign=text.align_left,  bgcolor=#1a1a2e, text_size=size.small)
    table.cell(infoTbl, 1, row, value, text_color=txtColor,    text_halign=text.align_right, bgcolor=#1a1a2e, text_size=size.small)

f_clear(row) =>
    table.cell(infoTbl, 0, row, "", bgcolor=#1a1a2e)
    table.cell(infoTbl, 1, row, "", bgcolor=#1a1a2e)

fmtPrice(x) => str.tostring(x, format.mintick)
fmtVol(x)   => str.tostring(x, format.volume)
fmt2(x)     => str.tostring(x, "#.##")

totalTrades = strategy.closedtrades
winTrades   = strategy.wintrades
lossTrades  = strategy.losstrades
winRate     = totalTrades > 0 ? 100.0 * winTrades / totalTrades : na
avgTrade    = totalTrades > 0 ? (strategy.netprofit / totalTrades) : na
profitFactor = strategy.grossloss != 0 ? math.abs(strategy.grossprofit / strategy.grossloss) : na

if barstate.islast and showTable
    f_set(0, "⚡ Breakout India", syminfo.ticker, color.yellow)
    f_set(1, "Mode", mode, color.aqua)
    f_set(2, "Price", fmtPrice(close))
    f_set(3, "ATR(14)", fmt2(atr14))
    f_set(4, "SL/TP", fmt2(atr14 * slMult) + " / " + fmt2(atr14 * tpMult), color.orange)

    if mode == "Prev Day"
        f_set(5, "Prev H/L", fmtPrice(prevHigh) + " / " + fmtPrice(prevLow))
    else if mode == "Bollinger"
        f_set(5, "BB", fmtPrice(bbUpper) + " / " + fmtPrice(bbLower))
    else if mode == "EMA Trend"
        tCol = trendUp ? color.green : trendDown ? color.red : color.white
        f_set(5, "Trend", trendUp ? "▲ Bullish" : trendDown ? "▼ Bearish" : "— Flat", tCol)
    else if mode == "RSI Confirm"
        rCol = rsiVal > 55 ? color.green : rsiVal < 45 ? color.red : color.white
        f_set(5, "RSI(14)", fmt2(rsiVal), rCol)
    else
        f_set(5, "Vol Ratio", fmt2(volume / volSma), volConfirm ? color.green : color.red)

    f_set(6, "Trades Today", str.tostring(tradesToday) + "/" + str.tostring(maxTrades))

    if showStats and totalTrades > 0
        netCol = strategy.netprofit >= 0 ? color.green : color.red
        f_set(7,  "Net P&L", "₹" + fmt2(strategy.netprofit), netCol)
        f_set(8,  "Win Rate", na(winRate) ? "—" : fmt2(winRate) + "%", winRate > 50 ? color.green : color.red)
        f_set(9,  "Profit Factor", na(profitFactor) ? "—" : fmt2(profitFactor), profitFactor > 1.5 ? color.green : color.orange)
        f_set(10, "Trades (W/L)", str.tostring(winTrades) + "/" + str.tostring(lossTrades))
    else
        f_clear(7), f_clear(8), f_clear(9), f_clear(10)
