# Data provider credentials

# --- Upstox v2 (Indian equities tick + 3yr history) ---
# Generate API key + secret at https://developer.upstox.com/
# Then run: npm run upstox:auth  (writes .data/upstox-token.json)
UPSTOX_API_KEY=
UPSTOX_API_SECRET=
# Optional — pre-loaded access token (otherwise read from .data/upstox-token.json)
# UPSTOX_ACCESS_TOKEN=

# --- Postgres (performance matrix) ---
# Use Supabase, Neon, or local Docker. Get connection string from provider.
# Example: postgresql://user:pass@db.host:5432/dbname?sslmode=require
DATABASE_URL=

# --- AI Meta-Layer (optional LLM explanations) ---
# Leave as 'none' to use deterministic heuristic ranker only.
# Set to 'openai' or 'anthropic' and add the matching key below to enable LLM.
LLM_PROVIDER=none
OPENAI_API_KEY=
ANTHROPIC_API_KEY=

# --- Telegram Bot ---
# Create a bot via @BotFather on Telegram, then get your chat ID from @userinfobot.
# In production (Fly.io), set these as secrets: fly secrets set TELEGRAM_BOT_TOKEN=xxx TELEGRAM_CHAT_ID=xxx
# You can also enable/configure Telegram from the dashboard Settings panel.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Cloud / Headless Deployment ---
# Set HEADLESS=true when running without TradingView Desktop (e.g. Fly.io, Docker).
# CDP-dependent features (chart control, Pine Script, replay) are unavailable in headless mode.
# All other features (Munafa scanner, strategy engine, Telegram, API) work normally.
HEADLESS=false
PORT=3456
TZ=Asia/Kolkata

# Set to true to enable the 8:00 AM / 8:30 AM cron scheduler on startup.
# The scheduler also starts automatically if Telegram is enabled and configured.
SCHEDULER_ENABLED=false
